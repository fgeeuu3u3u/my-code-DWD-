import pandas as pd
import numpy as np
import corner
import matplotlib.pyplot as plt
import matplotlib as mpl  # 添加缺失的导入
from matplotlib import colors
from matplotlib.cm import ScalarMappable

# 设置中文字体
plt.rcParams['font.sans-serif'] = ['SimHei', 'DejaVu Sans']
plt.rcParams['axes.unicode_minus'] = False

# 加载数据
conv = pd.read_hdf('dat_kstar1_10_12_kstar2_10_12_SFstart_13700.0_SFduration_0.0_metallicity_0.02.h5', key='conv')
initC = pd.read_hdf('dat_kstar1_10_12_kstar2_10_12_SFstart_13700.0_SFduration_0.0_metallicity_0.02.h5', key='initC')

# DWD 类型分类函数
def classify_dwd(k1, k2):
    if k1 == 10 and k2 == 10:
        return 'He+He'
    elif (k1 == 10 and k2 == 11) or (k1 == 11 and k2 == 10):
        return 'He+CO'
    elif k1 == 11 and k2 == 11:
        return 'CO+CO'
    elif k1 == 12 or k2 == 12:
        return 'ONe+X'
    else:
        return 'Other'

# 为conv数据添加DWD类型标签
conv['dwd_type'] = conv.apply(lambda r: classify_dwd(r['kstar_1'], r['kstar_2']), axis=1)

# 安全重置索引：如果bin_num是索引，则重置但不添加为列
if initC.index.names[0] == 'bin_num' and 'bin_num' in initC.columns:
    # bin_num既是索引又是列，重置索引但丢弃原索引
    initC_clean = initC.reset_index(drop=True)
else:
    initC_clean = initC.reset_index()

print(f"处理后initC形状: {initC_clean.shape}")

# 创建DWD类型映射
dwd_type_mapping = conv[['bin_num', 'dwd_type']].drop_duplicates()

# 合并initC与DWD类型信息
initC_with_dwd = pd.merge(initC_clean, dwd_type_mapping, on='bin_num', how='inner')

# 计算质量比
initC_with_dwd['q'] = initC_with_dwd['mass_2'] / initC_with_dwd['mass_1']

print(f"合并成功！合并后数据行数: {len(initC_with_dwd)}")
print("DWD类型分布:")
print(initC_with_dwd['dwd_type'].value_counts())

# 设置参数和颜色
parameters = ['mass_1', 'mass_2', 'porb', 'ecc', 'q']
dwd_types = ['He+He', 'He+CO', 'CO+CO', 'ONe+X']
colors_list = ['#1f77b4', '#ff7f0e', '#2ca02c', '#d62728']  # 修正变量名

labels = [
    "Mass1 (M$_{\odot}$)", 
    "Mass2 (M$_{\odot}$)", 
    "Orbital Period (days)", 
    "Eccentricity",
    "Mass Ratio (q)"
]

# 为每个DWD类型创建热力图形式的角图
successful_plots = []

for i, dwd_type in enumerate(dwd_types):
    print(f"\n处理 {dwd_type} 类型...")
    
    # 筛选当前DWD类型的数据
    type_data = initC_with_dwd[initC_with_dwd['dwd_type'] == dwd_type]
    
    if len(type_data) < 10:
        print(f"  - 数据点不足: {len(type_data)} 个")
        continue
    
    # 检查参数中是否有NaN值
    if type_data[parameters].isnull().any().any():
        print(f"  - 跳过，参数中包含NaN值")
        nan_columns = type_data[parameters].isnull().any()
        nan_cols = list(nan_columns[nan_columns].index)
        print(f"  - 包含NaN的列: {nan_cols}")
        continue
    
    print(f"  - 找到 {len(type_data)} 个有效系统")
    
    try:
        # 计算热力图的bins数量（基于数据量动态调整）
        n_bins = min(30, max(15, int(np.log10(len(type_data)) * 5)))
        print(f"  - 使用 {n_bins}×{n_bins} 的bins")
        
        # 创建热力图形式的角图
        fig = corner.corner(
            type_data[parameters],
            labels=labels,
            bins=n_bins,  # 使用动态计算的bins数量
            color=colors_list[i],
            plot_contours=True, #等高线绘制
            plot_datapoints=True,  # 大数据时开启散点
            fill_contours=False,
            hist_kwargs={'density': True, 'alpha': 0.7, 'color': colors_list[i]},
            # 热力图相关参数
            hist2d_kwargs={
                'cmap': 'viridis',  # 使用viridis颜色映射
                'norm': mpl.colors.LogNorm(vmin=1, vmax=None),  # 对数归一化
                'bins': n_bins,  # 二维直方图的bins
            },
            show_titles=True,
            title_fmt='.3f',
            title_kwargs={'fontsize': 10},
            figsize=(10, 10)  # 设置图形大小
        )
        
        # 添加颜色条
        # 找到二维直方图的axes
        ndim = len(parameters)
        axes = np.array(fig.axes).reshape((ndim, ndim))
        
        # 找到第一个二维子图来添加颜色条
        for i_idx in range(1, ndim):
            for j_idx in range(i_idx):
                ax = axes[i_idx, j_idx]
                collections = ax.collections
                for coll in collections:
                    if isinstance(coll, mpl.collections.QuadMesh):
                        # 创建颜色条
                        cbar = fig.colorbar(
                            coll, 
                            ax=axes[:, -1],  # 在最右侧的列上添加颜色条
                            pad=0.02,
                            shrink=0.8
                        )
                        cbar.set_label('Number of Systems', fontsize=12, rotation=270, labelpad=15)
                        break
                else:
                    continue
                break
            else:
                continue
            break
        
        # 添加总标题
        fig.suptitle(f'{dwd_type} DWD Systems - Initial Conditions (n={len(type_data):,})', 
                    fontsize=16, y=1.02, fontweight='bold')
        
        # 调整布局
        plt.tight_layout()
        
        # 保存图片
        filename = f'heatmap_corner_{dwd_type.replace("+", "_")}.png'
        fig.savefig(filename, dpi=300, bbox_inches='tight', facecolor='white')
        plt.close(fig)
        
        print(f"  - 已保存: {filename}")
        successful_plots.append(dwd_type)
        
    except Exception as e:
        print(f"  - 绘图错误: {e}")
        import traceback
        traceback.print_exc()

# 创建汇总统计信息
if successful_plots:
    print(f"\n=== 汇总统计 ===")
    for dwd_type in successful_plots:
        type_data = initC_with_dwd[initC_with_dwd['dwd_type'] == dwd_type]
        
        print(f"\n{dwd_type} 类型统计 (n={len(type_data):,}):")
        for param in parameters:
            data = type_data[param]
            if len(data) > 0:
                mean_val = data.mean()
                median_val = data.median()
                std_val = data.std()
                q1 = data.quantile(0.16)  # 相当于 -1σ
                q3 = data.quantile(0.84)  # 相当于 +1σ
                print(f"  {param}: {mean_val:.3f} ± {std_val:.3f} (median={median_val:.3f}, 16-84%=[{q1:.3f}, {q3:.3f}])")

print(f"\n完成！成功绘制 {len(successful_plots)} 个DWD类型的热力图角图")


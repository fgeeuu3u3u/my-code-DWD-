import matplotlib.pyplot as plt
import numpy as np
import pandas as pd
from matplotlib.colors import LogNorm
from matplotlib.ticker import LogLocator, LogFormatter, NullFormatter
import seaborn as sns

# 设置样式
plt.style.use('default')
sns.set_style("whitegrid")

# 创建图形和坐标轴
fig, ax = plt.subplots(1, 1, figsize=(12, 8))

# 提取数据
porb = conv['porb'].values
ecc = conv['ecc'].values

# 对周期数据取对数
log_porb = np.log10(porb + 1e-10)

# 创建2D直方图用于热力图
x_bins = 200
y_bins = 50

# 计算2D直方图
hist, x_edges, y_edges = np.histogram2d(
    log_porb, ecc, 
    bins=[x_bins, y_bins],
    range=[[log_porb.min(), log_porb.max()], [0, 1]]
)

# 处理数据中的0值，避免对数计算问题
hist_data = hist.T.copy()
nonzero_min = hist_data[hist_data > 0].min() if np.any(hist_data > 0) else 1
hist_data[hist_data == 0] = nonzero_min / 5

# 使用LogNorm
vmin = max(1e-3, hist_data.min())
vmax = hist_data.max()

im = ax.imshow(
    hist_data,
    aspect='auto', 
    origin='lower',
    extent=[x_edges[0], x_edges[-1], y_edges[0], y_edges[-1]],
    cmap='viridis',
    interpolation='nearest',
    norm=LogNorm(vmin=vmin, vmax=vmax)
)

# 设置横轴刻度
period_ticks = [0.01, 0.1, 1, 10, 100, 1000, 10000, 100000, 1000000]
log_ticks = [np.log10(x) for x in period_ticks]

# 设置刻度位置
ax.set_xticks(log_ticks)

# 设置刻度标签为10的次方表示
ax.set_xticklabels([f'$10^{{{int(np.log10(x))}}}$' for x in period_ticks])


# 设置纵轴刻度
ax.set_yticks(np.arange(0, 1.1, 0.2))
# 设置轴标签
ax.set_xlabel('Period (days)', fontsize=12)
ax.set_ylabel('Eccentricity', fontsize=12)
# 添加颜色条
cbar = plt.colorbar(im, ax=ax, shrink=0.8)
cbar.set_label('Number', fontsize=12)

plt.tight_layout()
plt.show()
